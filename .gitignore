# Secrets — never commit these
.env

# Agent outputs — too large for git
*.mp4
*.mp3
*.wav
weekly_report.md

# Keep these out of the repo but let Actions upload them as artifacts
squad2_output/

# Allow seen_items.json — needed for dedup persistence across runs
!seen_items.json

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Keep README and example files
!README.md
!.env.example
