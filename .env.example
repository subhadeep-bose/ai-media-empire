# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# LLM
OLLAMA_MODEL=llama3:8b
GROQ_API_KEY=your_groq_api_key_here

# Pexels (free stock footage)
PEXELS_API_KEY=your_pexels_api_key_here

# Amazon Associates
AMAZON_AFFILIATE_TAG=your_tag_here

# Newsletter (Beehiiv)
BEEHIIV_API_KEY=your_beehiiv_api_key_here

# Social (add as you set up accounts)
IG_ACCESS_TOKEN=your_instagram_graph_api_token
YOUTUBE_API_KEY=your_youtube_data_api_key

# Notifications — daily roundup GitHub Issue + approval email
# GITHUB_TOKEN is set automatically in GitHub Actions; only needed locally
GITHUB_TOKEN=your_github_token_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password_here
NOTIFY_EMAIL_TO=your_email@gmail.com

# Notifications — Telegram dashboard (stat-tile snapshot + summary)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Notifications — per-agent Telegram bots (optional)
# Create one bot per agent via @BotFather to give each a distinct identity
# in Telegram's chat list. Any agent without a token here just skips its
# own Telegram update; the shared TELEGRAM_CHAT_ID above is reused for all.
TELEGRAM_BOT_TOKEN_CHIEF_OF_STAFF=your_bot_token_here
TELEGRAM_BOT_TOKEN_SQUAD1_INTEL=your_bot_token_here
TELEGRAM_BOT_TOKEN_SQUAD2_NEWSLETTER=your_bot_token_here
TELEGRAM_BOT_TOKEN_SQUAD2_TWITTER=your_bot_token_here
TELEGRAM_BOT_TOKEN_SQUAD2_REELS=your_bot_token_here
TELEGRAM_BOT_TOKEN_SQUAD3_PRODUCTION=your_bot_token_here
TELEGRAM_BOT_TOKEN_SQUAD6_ANALYTICS=your_bot_token_here
